# Copy this file to .env.local and fill in real values.

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox (account.mapbox.com -> Tokens). Free tier is plenty for an MVP.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Admin password — server-side only, never exposed to the browser
# Set this in Vercel WITHOUT the NEXT_PUBLIC_ prefix
ADMIN_PASSWORD=

# SEO indexing — set to "true" when ready to go public, leave unset to block all crawlers
NEXT_PUBLIC_ALLOW_INDEXING=
