# Copy this file to .env.local and fill in real values.

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox (account.mapbox.com -> Tokens). Free tier is plenty for an MVP.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Simple shared password for /admin -- NOT real authentication, just a
# deterrent. Anyone who can read your deployed JS can see this value, so
# don't reuse a real password here.
NEXT_PUBLIC_ADMIN_PASSWORD=

# Geopath (not yet wired up -- see lib/geopath.ts)
GEOPATH_API_KEY=
